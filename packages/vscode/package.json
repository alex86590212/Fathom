{
  "name": "fathom",
  "displayName": "Fathom",
  "description": "Code comprehension risk visualization — 2×2 risk matrix heatmap",
  "version": "0.1.0",
  "publisher": "fathom",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Linters"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fathom.check",
        "title": "Fathom: Check Test Honesty"
      },
      {
        "command": "fathom.showMatrix",
        "title": "Fathom: Show Risk Matrix"
      }
    ],
    "configuration": {
      "title": "Fathom",
      "properties": {
        "fathom.analyzerPath": {
          "type": "string",
          "default": "",
          "description": "Full path to fathom CLI. Leave empty to use python -m fathom."
        },
        "fathom.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable for python -m fathom when analyzerPath is empty"
        },
        "fathom.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Claude API key for on-demand red-zone explanations (Phase 4)"
        },
        "fathom.dataDir": {
          "type": "string",
          "default": ".fathom",
          "description": "Local per-developer data directory (gitignored)"
        }
      }
    },
    "colors": [
      {
        "id": "fathom.critical",
        "description": "Critical risk zone gutter",
        "defaults": { "dark": "#e06c75", "light": "#c53b45" }
      },
      {
        "id": "fathom.fragile",
        "description": "Fragile confidence zone gutter",
        "defaults": { "dark": "#e5c07b", "light": "#b8941f" }
      },
      {
        "id": "fathom.blindSpot",
        "description": "Blind spot zone gutter",
        "defaults": { "dark": "#61afef", "light": "#2b7cd3" }
      },
      {
        "id": "fathom.healthy",
        "description": "Healthy zone gutter",
        "defaults": { "dark": "#98c379", "light": "#4a8f2a" }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "packageManager": "npm@10.0.0",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
